{
  "name": "vibetracker",
  "displayName": "VibeTracker",
  "description": "Track your vibe coding activity and update GitHub profile with styled metrics",
  "version": "0.1.0",
  "publisher": "victorlobato",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibetracker.start",
        "title": "VibeTracker: Start Tracking"
      },
      {
        "command": "vibetracker.stop",
        "title": "VibeTracker: Stop Tracking"
      },
      {
        "command": "vibetracker.dashboard",
        "title": "VibeTracker: Open Dashboard"
      },
      {
        "command": "vibetracker.setApiKey",
        "title": "VibeTracker: Set Gemini API Key"
      },
      {
        "command": "vibetracker.setTemplate",
        "title": "VibeTracker: Select SVG Template"
      },
      {
        "command": "vibetracker.status",
        "title": "VibeTracker: Show Status"
      }
    ],
    "configuration": {
      "title": "VibeTracker",
      "properties": {
        "vibetracker.shadowRepoName": {
          "type": "string",
          "default": "vibetracker-logs",
          "description": "Name of the private shadow repository for activity logs"
        },
        "vibetracker.flushInterval": {
          "type": "number",
          "default": 30,
          "description": "Minutes of inactivity before auto-committing session data"
        },
        "vibetracker.savesThreshold": {
          "type": "number",
          "default": 50,
          "description": "Number of file saves before auto-committing"
        },
        "vibetracker.template": {
          "type": "string",
          "default": "artistic",
          "enum": ["artistic", "cyber", "retro"],
          "description": "SVG template style for the profile README"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --watch",
    "lint": "echo lint-ok",
    "pretest": "npm run build",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.2",
    "@types/node": "^25.7.0",
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@google/genai": "^2.1.0",
    "jsdom": "^29.1.1",
    "octokit": "^5.0.5",
    "roughjs": "^4.6.6"
  }
}
